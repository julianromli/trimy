{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Trimy",
  "version": "0.1.0",
  "identifier": "com.faizintifada.trimy",
  "build": {
    "frontendDist": "../web/out",
    "devUrl": "http://localhost:3000/projects",
    "beforeDevCommand": "cd ../.. && bun run dev:web",
    "beforeBuildCommand": "cd ../.. && bun run build:web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Trimy",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
